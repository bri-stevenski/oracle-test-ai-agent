{
  "version": 1,
  "name": "oracle",
  "language": "python",
  "template": {
    "language": "python",
    "version": 1,
    "level": "intermediate"
  },
  "tooling": {
    "packageManager": "pip",
    "linter": "ruff",
    "formatter": "ruff",
    "testRunner": "pytest"
  },
  "layers": [
    {
      "name": "llm",
      "pattern": "agent/llm/**",
      "allowedDependencies": []
    },
    {
      "name": "core",
      "pattern": "agent/core/**",
      "allowedDependencies": [
        "llm"
      ]
    },
    {
      "name": "cli",
      "pattern": "agent/cli.py",
      "allowedDependencies": [
        "core",
        "llm"
      ]
    },
    {
      "name": "tests",
      "pattern": "tests/**",
      "allowedDependencies": [
        "core",
        "llm"
      ]
    }
  ],
  "forbiddenImports": [
    {
      "from": "agent/llm/**",
      "disallow": [
        "agent/core/**",
        "agent/cli.py"
      ],
      "message": "LLM layer must remain isolated from business logic and CLI."
    }
  ],
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "entryPoints": [
    "agent.cli:app"
  ],
  "telemetry": {
    "enabled": true
  },
  "adoption": {
    "enabled": true
  }
}
